rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Auxiliares básicos
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Verifica se o usuário tem perfil no Firestore e se é admin ou partner
    // Nota: Usamos (default) para o banco de dados padrão
    function isStaff() {
      return isSignedIn() && 
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'partner');
    }

    // Regras para Mídias de Eventos (Landing Pages)
    match /events/{eventId}/assets/{allPaths=**} {
      // Qualquer um pode ver as capas e backgrounds das festas
      allow read: if true;
      // Apenas equipe interna pode subir ou alterar mídias
      allow write: if isStaff();
    }

    // Regras para Comprovantes de Pagamento (Privado)
    match /events/{eventId}/payment_proofs/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Regras para Branding (Logo da Agência)
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Regras para Catálogo de Locação
    match /rental_items/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    // Bloqueio padrão para qualquer outro caminho
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}