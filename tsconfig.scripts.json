{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/scripts",
    "resolveJsonModule": true
  },
  "include": [
    "scripts/**/*.ts"
  ]
}
