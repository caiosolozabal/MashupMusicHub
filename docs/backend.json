
{
  "entities": {
    "GuestEvent": {
      "title": "GuestEvent",
      "description": "Evento pai para captação de convidados.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "mediaUrl": { "type": "string", "description": "URL do vídeo ou imagem principal." },
        "backgroundUrl": { "type": "string", "description": "Imagem de fundo da landing page." },
        "promoText": { "type": "string", "description": "Texto descritivo do evento." },
        "curfewAt": { "type": "string", "format": "date-time", "description": "Horário de fechamento automático das listas." },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GuestList": {
      "title": "GuestList",
      "description": "Segmento de lista dentro de um evento (ex: VIP, Promoter X).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string", "description": "Slug único para a URL pública." },
        "capacity": { "type": "number", "description": "Limite opcional de nomes." },
        "statsToken": { "type": "string", "description": "Token para acesso às estatísticas sem login." },
        "customMediaUrl": { "type": "string", "description": "Sobrescreve a mídia do evento se necessário." },
        "submissionCount": { "type": "number", "default": 0 }
      }
    },
    "GuestSubmission": {
      "title": "GuestSubmission",
      "description": "Registro individual de um convidado em uma lista.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "listId": { "type": "string" },
        "contactId": { "type": "string", "description": "Referência ao contato único no CRM." },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "email": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "CRM Global - Dados consolidados do frequentador.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UUID gerado pelo sistema." },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "email": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "lastActivity": { "type": "string", "format": "date-time" },
        "attendanceCount": { "type": "number" }
      }
    },
    "UrlSlug": {
      "title": "UrlSlug",
      "description": "Índice de slugs para busca rápida de páginas públicas.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["list"] },
        "eventId": { "type": "string" },
        "listId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/guest_events/{eventId}",
        "definition": { "entityName": "GuestEvent", "description": "Configurações globais do evento de captação." }
      },
      {
        "path": "/guest_events/{eventId}/lists/{listId}",
        "definition": { "entityName": "GuestList", "description": "Listas específicas vinculadas ao evento." }
      },
      {
        "path": "/guest_submissions/{submissionId}",
        "definition": { "entityName": "GuestSubmission", "description": "Entradas brutas dos formulários." }
      },
      {
        "path": "/contacts/{contactId}",
        "definition": { "entityName": "Contact", "description": "Base de dados consolidada (CRM)." }
      },
      {
        "path": "/slugs/{slug}",
        "definition": { "entityName": "UrlSlug", "description": "Mapeamento de URLs amigáveis." }
      }
    ]
  }
}
