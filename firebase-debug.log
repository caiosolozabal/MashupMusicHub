      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);\n      \n      // DELETE: Admins, partners, and the assigned DJ can delete their own event.\n      allow delete: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);\n    }\n    \n    // AGENCY ACCOUNTS (/agency_accounts/{accountId})\n    // Only admins and partners can manage agency accounts.\n    match /agency_accounts/{accountId} {\n        allow read, write, create, update, delete: if isAdmin() || isPartner();\n        allow list: if isAdmin() || isPartner();\n    }\n\n    // SETTLEMENTS (/settlements/{settlementId})\n    match /settlements/{settlementId} {\n      // CREATE: Only admins and partners can create settlements.\n      allow create: if isAdmin() || isPartner();\n\n      // READ: Admins, partners, and the specific DJ the settlement belongs to.\n      allow read: if isAdmin() || isPartner() || (isDj() && resource.data.djId == request.auth.uid);\n      \n      // LIST: Only Admins/Partners can list all. DJs can only list their own.\n      allow list: if isAdmin() || isPartner() || (isDj() && request.query.where.djId == request.auth.uid);\n\n      // UPDATE: Only admins and partners can update (e.g., mark as paid).\n      allow update: if isAdmin() || isPartner();\n      \n      // DELETE: Not recommended, but if necessary, restrict to admins.\n      allow delete: if isAdmin();\n    }\n  }\n}\n"}]}}
