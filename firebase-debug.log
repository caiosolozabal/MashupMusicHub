[debug] [2026-01-09T16:24:53.386Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAdmin() {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    function isPartner() {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';\n    }\n\n    function isDj() {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj';\n    }\n    \n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    match /users/{userId} {\n      allow read, update, create: if request.auth.uid == userId || isAdmin() || isPartner();\n      allow list: if isAdmin() || isPartner();\n    }\n    \n    match /agency_accounts/{accountId} {\n       allow read, list: if isAdmin() || isPartner();\n       allow create, update, delete: if isAdmin() || isPartner();\n    }\n\n    match /events/{eventId} {\n      // Todos os usuários autenticados podem ler/listar eventos para a funcionalidade principal da agenda.\n      allow read, list: if isSignedIn();\n      // Apenas Admins, Sócios podem criar/atualizar. DJs podem criar/atualizar SE o dj_id for o seu próprio.\n      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);\n      // Apenas Admins e Sócios podem deletar eventos.\n      allow delete: if isAdmin() || isPartner();\n    }\n    \n    match /settlements/{settlementId} {\n        // DJs podem ler seus próprios fechamentos, Admins e Sócios podem ler todos.\n        allow read, list: if isAdmin() || isPartner() || (isDj() && resource.data.djId == request.auth.uid);\n        // Apenas Admins e Sócios podem criar, atualizar ou deletar fechamentos.\n        allow create, update, delete: if isAdmin() || isPartner();\n    }\n\n    // Regra de fallback mais segura: nega todas as outras leituras/escritas.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
