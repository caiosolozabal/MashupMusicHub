[debug] [2025-07-21T22:54:53.686Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    // 🔐 users\n    match /users/{userId} {\n      // Admins/Partners podem ler qualquer perfil. Usuários podem ler o próprio perfil.\n      allow read: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      // Qualquer usuário autenticado pode criar seu próprio registro de usuário.\n      allow create: if request.auth.uid != null;\n      // Admins/Partners podem atualizar qualquer perfil. Usuários podem atualizar o próprio perfil.\n      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      // Ninguém pode deletar um usuário diretamente pelas regras.\n      allow delete: if false;\n    }\n\n    // 🔐 events\n    match /events/{eventId} {\n      // Admins/Partners podem ler qualquer evento. DJs podem ler eventos atribuídos a eles.\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      // Admins, Partners e DJs podem criar eventos.\n      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];\n      // Admins/Partners podem atualizar qualquer evento. DJs podem atualizar eventos atribuídos a eles.\n      allow update: if request.auth.token.role in ['admin', 'partner'] || \n                     (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      // Apenas Admins/Partners podem deletar eventos.\n      allow delete: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 settlements\n    match /settlements/{settlementId} {\n      // Admins/Partners podem ler qualquer fechamento. DJs podem ler seus próprios fechamentos.\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);\n      // Apenas Admins/Partners podem criar, atualizar ou deletar fechamentos.\n      allow write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 agency_accounts\n    match /agency_accounts/{accountId} {\n      // Apenas Admins/Partners podem ler ou escrever nas contas da agência.\n      allow read, write: if request.auth.token.role in ['admin', 'partner'];\n    }\n  }\n}\n"}]}}
