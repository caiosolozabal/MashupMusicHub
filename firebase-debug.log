[debug] [2026-01-06T04:03:27.169Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    function getRole(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role;\n    }\n\n    function isAdmin() {\n      return isSignedIn() && getRole(request.auth.uid) == 'admin';\n    }\n\n    function isPartner() {\n      return isSignedIn() && getRole(request.auth.uid) == 'partner';\n    }\n\n    function isDj() {\n       return isSignedIn() && getRole(request.auth.uid) == 'dj';\n    }\n\n    // USER PROFILES\n    // Users can read/update their own profile. Admins/partners can read any profile and update any profile.\n    match /users/{userId} {\n      allow read, update: if (isSignedIn() && (isOwner(userId) || isAdmin() || isPartner()));\n      // Allow create for new users (though this is typically handled by trusted server code or first login)\n      allow create: if isSignedIn();\n    }\n\n    // AGENCY ACCOUNTS\n    // Only admins and partners can manage agency accounts.\n    match /agency_accounts/{accountId} {\n      allow read, create, update, delete: if isAdmin() || isPartner();\n    }\n\n    // EVENTS\n    // Admins/partners can do anything. DJs can create events and read/update events assigned to them.\n    match /events/{eventId} {\n      allow read: if (isAdmin() || isPartner()) || (isDj() && resource.data.dj_id == request.auth.uid);\n      allow create: if isAdmin() || isPartner() || isDj();\n      allow update: if (isAdmin() || isPartner()) || (isDj() && resource.data.dj_id == request.auth.uid);\n      // Deletion is admin/partner only for data integrity.\n      allow delete: if isAdmin() || isPartner();\n    }\n  }\n}\n"}]}}
