[debug] [2025-07-21T23:01:10.697Z] >>> [apiv2][query] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules [none]
[debug] [2025-07-21T23:01:10.698Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function isOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n\n    // 🔐 users\n    match /users/{userId} {\n      // Admins/Partners can get any user. Users can get their own profile.\n      allow get: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      // Admins/Partners can list users (e.g., to populate DJ dropdowns).\n      allow list: if request.auth.token.role in ['admin', 'partner'];\n      // Users can create their own document.\n      allow create: if isOwner(userId);\n      // Admins/Partners can update any user. Users can update their own profile.\n      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      // Deletion is not allowed.\n      allow delete: if false;\n    }\n\n    // 🔐 events\n    match /events/{eventId} {\n      // Admins/Partners can read any event. DJs can read their own events.\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      // Admins, Partners, and DJs can create events.\n      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];\n      // Admins/Partners can update any event. DJs can update their own events.\n      allow update: if request.auth.token.role in ['admin', 'partner'] || \n                     (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      // Only Admins/Partners can delete events.\n      allow delete: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 settlements\n    match /settlements/{settlementId} {\n       // Admins/Partners can read any settlement. DJs can read their own settlements.\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);\n      // Only Admins/Partners can write settlements.\n      allow write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 agency_accounts\n    match /agency_accounts/{accountId} {\n      // Only Admins/Partners can read/write agency accounts.\n      allow read, write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔒 fallback: deny all other reads/writes\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
