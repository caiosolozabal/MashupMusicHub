[debug] [2026-01-06T03:47:08.654Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"/**\n * Core Philosophy:\n * This ruleset implements a Role-Based Access Control (RBAC) model combined with\n * a strict user-ownership model. Administrative users (admins) have broad\n * privileges, while standard users have explicit ownership of their data, such as\n * their user profile and promoter-specific guest lists. Sensitive financial\n * data is further restricted to 'admin' and 'finance' roles.\n *\n * Data Structure:\n * The data is organized into a mix of top-level collections for shared data\n * (e.g., /events, /djs) and user-scoped subcollections for private data\n * (e.g., /users/{userId}/...). A dedicated collection, /roles_admin, is used for\n * an efficient, non-hierarchical lookup of admin privileges.\n *\n * Key Security Decisions:\n * - Admin Access: A user is considered an admin if a document with their UID\n *   exists in the /roles_admin collection. This is a highly performant and\n *   scalable way to manage global permissions.\n * - User Privacy: Direct listing of the top-level /users collection is\n *   disallowed to protect user privacy. Users can only access their own data\n *   tree under /users/{userId}.\n * - Event Access Control: Due to the current data model, which lacks a denormalized\n *   list of collaborator UIDs on event documents, access to /events and their\n *   subcollections is restricted to admins to ensure security. This prevents\n *   unauthorized data access and is the safest default. The rules include comments\n *   on how to expand this if the data model is updated.\n * - Financial Data: Access to sensitive collections like /accounts and DJ\n *   settlements (/djs/{djId}/settlements) is strictly limited to users with\n *   'admin' or 'finance' roles, or in the case of settlements, the DJ who owns it.\n *\n * Denormalization for Authorization:\n * This ruleset relies on denormalization to function securely and efficiently.\n * - The `promoterId` is denormalized onto `GuestList` documents, allowing rules\n *   to grant write access without needing to read a separate user profile.\n * - The `djId` field on a user's profile links their authentication UID to their\n *   DJ record, enabling rules for settlements to verify ownership.\n *\n * Structural Segregation:\n * The ruleset leverages distinct paths for data with different access patterns.\n * For example, promoter-owned guest lists are stored under the user's private\n * path (/users/{userId}/guestLists), while event-specific guest lists are stored\n * under the public event path (/events/{eventId}/guestLists). This separation\n * simplifies list queries and enhances security.\n */\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // -------------------------------------------------------------------------\n    // Helper Functions\n    // -------------------------------------------------------------------------\n\n    /**\n     * Returns true if the user is authenticated.\n     */\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    /**\n     * Returns true if the authenticated user's UID matches the provided userId.\n     * Used to enforce document and data tree ownership.\n     */\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    /**\n     * Returns true if the resource existed before the request.\n     * CRITICAL for all update and delete operations to prevent acting on\n     * non-existent documents.\n     */\n    function docExists() {\n      return resource != null;\n    }\n\n    /**\n     * Returns true if the user has administrative privileges.\n     * Checks for the existence of a document in the /roles_admin collection.\n     */\n    function isAdmin() {\n      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));\n    }\n\n    /**\n     * Retrieves the requesting user's profile data document.\n     * This function is used to check for user roles and other profile-based attributes.\n     */\n    function getUserData() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)/profile).data;\n    }\n\n\n\n    /**\n     * Retrieves the role string from the user's profile.\n     */\n    function getUserRole() {\n      return getUserData().role;\n    }\n\n    /**\n     * Returns true if the user is an admin or has the 'finance' role.\n     * Used to protect sensitive financial collections.\n     */\n    function isAdminOrFinance() {\n      return isAdmin() || (isSignedIn() && getUserRole() == 'finance');\n    }\n\n    /**\n     * Checks if the current user is the DJ associated with the given djId.\n     * This is used to secure a DJ's personal settlement data.\n     */\n    function isAssociatedDJ(djId) {\n      return isSignedIn() && getUserData().djId == djId && getUserRole() == 'dj';\n    }\n\n\n    // -------------------------------------------------------------------------\n    // User Data (/users)\n    // -------------------------------------------------------------------------\n\n    /**\n     * @description Users can manage their own profile, but cannot see or list other users' profiles.\n     * @path        /users/{userId}/profile/{profileId}\n     * @allow       A user (auth.uid='user123') creates their own profile document at /users/user123/profile/{profileId}. (create)\n     * @deny        A user (auth.uid='user456') tries to read the profile at /users/user123/profile/{profileId}. (get)\n     * @principle   Restricts access to a user's own data tree and enforces ownership.\n     */\n    match /users/{userId}/profile/{profileId} {\n      allow get, list, update, delete: if isOwner(userId);\n      allow create: if isOwner(userId) && request.resource.data.id == userId;\n    }\n\n    /**\n     * @description Users can manage their own private guest lists.\n     * @path        /users/{userId}/guestLists/{guestListId}\n     * @allow       A promoter (auth.uid='user123') creates a guest list under their own path. (create)\n     * @deny        A promoter (auth.uid='user456') tries to delete a guest list under /users/user123/guestLists/{guestListId}. (delete)\n     * @principle   Enforces strict ownership for all operations within a user's private data space.\n     */\n    match /users/{userId}/guestLists/{guestListId} {\n      allow get, list: if isOwner(userId);\n      allow create: if isOwner(userId) && request.resource.data.promoterId == userId;\n      allow update, delete: if docExists() && isOwner(userId);\n    }\n\n    // -------------------------------------------------------------------------\n    // Administrative Roles (/roles_admin)\n    // -------------------------------------------------------------------------\n\n    /**\n     * @description Only other admins can manage the list of admins. This collection is not readable by normal users.\n     * @path        /roles_admin/{userId}\n     * @allow       An admin creates a document for a new admin at /roles_admin/newUser123. (create)\n     * @deny        A non-admin user tries to read any document in this collection. (get, list)\n     * @principle   Secures administrative privileges by restricting modification of the role list to existing admins.\n     */\n    match /roles_admin/{userId} {\n      allow get, list, create, update, delete: if isAdmin();\n    }\n\n\n    // -------------------------------------------------------------------------\n    // Core Data Collections (/events, /djs, /accounts)\n    // -------------------------------------------------------------------------\n\n    /**\n     * @description Manages event information.\n     * @path        /events/{eventId}\n     * @allow       An admin creates, updates, or deletes an event document. (create, update, delete)\n     * @deny        A regular DJ user attempts to read or modify an event. (get, list, create, update, delete)\n     * @principle   Restricts access to admins as a secure default. The data model lacks a denormalized list of user UIDs\n     *              (e.g., a `memberUids` map) required to safely grant access to collaborators like DJs.\n     */\n    match /events/{eventId} {\n      // TODO: To grant DJs or other collaborators access, denormalize a `memberUids` map onto this document\n      // (e.g., { memberUids: { 'user-uid-of-dj': 'dj', 'user-uid-of-manager': 'manager' } })\n      // and update the rule to: `isAdmin() || request.auth.uid in resource.data.memberUids`.\n      allow get, list, create, update, delete: if isAdmin();\n    }\n\n    /**\n     * @description Manages guest lists associated with a specific event.\n     * @path        /events/{eventId}/guestLists/{guestListId}\n     * @allow       A promoter creates a guest list for an event, setting their own UID as the 'promoterId'. (create)\n     * @deny        A promoter tries to update a guest list where they are not the 'promoterId'. (update)\n     * @principle   Allows any signed-in user to create a list for an event, but write access is restricted to the list's owner (promoter) or an admin.\n     */\n    match /events/{eventId}/guestLists/{guestListId} {\n      allow get, list: if isSignedIn();\n      allow create: if isSignedIn() && request.resource.data.promoterId == request.auth.uid && request.resource.data.eventId == eventId;\n      allow update, delete: if docExists() && (isOwner(resource.data.promoterId) || isAdmin());\n    }\n\n    /**\n     * @description Manages documents (e.g., contracts) associated with a specific event.\n     * @path        /events/{eventId}/documents/{documentId}\n     * @allow       An admin uploads a contract for an event. (create)\n     * @deny        A DJ tries to view or list event documents. (get, list)\n     * @principle   Inherits permissions from the parent event, restricting all access to admins as a secure default.\n     */\n    match /events/{eventId}/documents/{documentId} {\n      allow get, list, delete, update: if docExists() && isAdmin();\n      allow create: if isAdmin() && request.resource.data.eventId == eventId;\n    }\n\n    /**\n     * @description Stores public profiles for DJs.\n     * @path        /djs/{djId}\n     * @allow       Any authenticated user can read the list of DJs and their profiles. (get, list)\n     * @deny        A regular user tries to update a DJ's profile information. (update)\n     * @principle   Public read for general application use, with writes restricted to administrators.\n     */\n    match /djs/{djId} {\n      allow get, list: if isSignedIn();\n      allow create, update, delete: if isAdmin();\n    }\n\n    /**\n     * @description Manages financial settlements for DJs. Access is highly restricted.\n     * @path        /djs/{djId}/settlements/{settlementId}\n     * @allow       A DJ with a matching 'djId' on their user profile views their own settlement. (get)\n     * @allow       A user with the 'finance' role creates a new settlement for a DJ. (create)\n     * @deny        A DJ tries to view the settlements of another DJ. (get, list)\n     * @principle   Restricts access to sensitive financial data to the document owner (the DJ) or authorized financial staff.\n     */\n    match /djs/{djId}/settlements/{settlementId} {\n      allow get, list: if isAssociatedDJ(djId) || isAdminOrFinance();\n      allow create: if (isAssociatedDJ(djId) || isAdminOrFinance()) && request.resource.data.djId == djId;\n      allow update, delete: if docExists() && (isAssociatedDJ(djId) || isAdminOrFinance());\n    }\n\n    /**\n     * @description Manages sensitive bank account information for the agency.\n     * @path        /accounts/{accountId}\n     * @allow       A user with the 'finance' role reads an account's details. (get)\n     * @deny        Any user without an 'admin' or 'finance' role attempts any operation. (get, list, create, update, delete)\n     * @principle   Enforces strict role-based access for highly sensitive financial information.\n     */\n    match /accounts/{accountId} {\n      allow get, list, create, update, delete: if isAdminOrFinance();\n    }\n\n    // CRITICAL: The IR defines a path \"/guestLists/{guestListId}/guests/{guestId}\" but no top-level \"/guestLists\" collection.\n    // This rule is omitted because it cannot be securely implemented without a clear parent collection.\n    // Guests should be a subcollection of a specific guest list, e.g., /events/{eventId}/guestLists/{guestListId}/guests/{guestId}.\n\n  }\n}"}]}}
