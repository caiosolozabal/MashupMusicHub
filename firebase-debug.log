[debug] [2025-07-09T19:36:31.746Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if a user is an admin or partner\n    function isAdminOrPartner(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data.role in ['admin', 'partner'];\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Any authenticated user can read their own data\n      // Admins/partners can read any user's data\n      allow read: if request.auth.uid == userId || isAdminOrPartner(request.auth.uid);\n\n      // Only the user themselves can update their own data.\n      // Admins/partners can also update any user's data.\n      allow write: if request.auth.uid == userId || isAdminOrPartner(request.auth.uid);\n      \n      // Creating a user document is handled by the AuthProvider on first login\n      allow create: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'events' collection\n    match /events/{eventId} {\n        // Admins and partners can read any event.\n        // DJs can read events assigned to them.\n        allow read: if isAdminOrPartner(request.auth.uid) || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj' && resource.data.dj_id == request.auth.uid);\n\n        // Admins and partners can create, update, and delete any event.\n        // DJs can create events and update events assigned to them.\n        allow create: if request.auth != null; // Any authenticated user can create, logic is handled in UI\n        allow update: if isAdminOrPartner(request.auth.uid) || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj' && resource.data.dj_id == request.auth.uid);\n        allow delete: if isAdminOrPartner(request.auth.uid);\n    }\n    \n    // Rules for the 'settlements' collection\n    match /settlements/{settlementId} {\n        // Admins and partners can manage settlements\n        allow read, write, create, delete: if isAdminOrPartner(request.auth.uid);\n    }\n    \n    // Rules for the 'agency_accounts' collection\n    match /agency_accounts/{accountId} {\n      // Only admins and partners can manage agency accounts\n      allow read, write, create, delete: if isAdminOrPartner(request.auth.uid);\n    }\n  }\n}\n"}]}}
