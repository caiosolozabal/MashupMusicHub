[debug] [2025-07-10T03:24:32.129Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to make rules more readable and reusable.\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    function isAdminOrPartner() {\n      return isAuth() && request.auth.token.role in ['admin', 'partner'];\n    }\n\n    function isOwner(userId) {\n      return isAuth() && request.auth.uid == userId;\n    }\n\n    // --- User Profiles ---\n    match /users/{userId} {\n      // Admins/Partners can read any user profile (to list DJs, etc.).\n      // Any authenticated user can read their own profile.\n      allow read: if isAdminOrPartner() || isOwner(userId);\n\n      // Only an authenticated user can update their own profile.\n      // Admins/Partners can update any profile (to change roles, etc.).\n      allow update: if isAdminOrPartner() || isOwner(userId);\n      \n      // Prevent user creation from client-side for security.\n      // Creation should be handled by server-side logic (Firebase Auth triggers).\n      allow create: if isAuth();\n    }\n\n    // --- Events ---\n    match /events/{eventId} {\n      // Admins/Partners can read/write all events.\n      allow read, write: if isAdminOrPartner();\n\n      // DJs can read events they are assigned to.\n      // They can also create new events for themselves.\n      // They can only update events they are assigned to.\n      allow read, update: if isAuth() && resource.data.dj_id == request.auth.uid;\n      allow create: if isAuth();\n    }\n    \n    // --- Financial Settlements ---\n    match /settlements/{settlementId} {\n        // Admins/Partners can read/write all settlements.\n        allow read, write: if isAdminOrPartner();\n\n        // DJs can only read settlements that belong to them.\n        allow read: if isAuth() && resource.data.djId == request.auth.uid;\n    }\n\n    // --- Agency Bank Accounts ---\n    match /agency_accounts/{accountId} {\n      // Only Admins/Partners can manage agency bank accounts.\n      allow read, write: if isAdminOrPartner();\n    }\n  }\n}\n"}]}}
