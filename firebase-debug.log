[debug] [2025-07-09T19:31:16.678Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check for admin/partner roles\n    function isPrivileged() {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'partner'];\n    }\n    \n    // Helper function to check if the user is the owner of the document\n    function isOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n\n    // /users/{userId}\n    match /users/{userId} {\n      // Anyone can create their own user document on first login (handled by AuthContext)\n      allow create: if request.auth != null && request.auth.uid == userId;\n      // Users can read their own data. Privileged users can read anyone's data.\n      allow read: if isOwner(userId) || isPrivileged();\n      // Users can update their own data. Privileged users can update anyone's data.\n      allow update: if isOwner(userId) || isPrivileged();\n      // Only privileged users can delete user accounts from Firestore.\n      allow delete: if isPrivileged();\n    }\n\n    // /events/{eventId}\n    match /events/{eventId} {\n      // Read: Privileged users can read all. DJs can read events assigned to them.\n      allow read: if isPrivileged() || (request.auth != null && resource.data.dj_id == request.auth.uid);\n      // Create: Any authenticated user can create an event (DJ, admin, partner).\n      allow create: if request.auth != null;\n      // Update: Privileged users can update any event. DJs can only update events assigned to them.\n      // Also allow updating settlementId by privileged users.\n      allow update: if isPrivileged() || (request.auth != null && resource.data.dj_id == request.auth.uid);\n      // Delete: Only privileged users can delete events.\n      allow delete: if isPrivileged();\n    }\n    \n    // /agency_accounts/{accountId}\n    match /agency_accounts/{accountId} {\n        // Only privileged users can manage agency accounts.\n    \tallow read, write: if isPrivileged();\n    }\n\n    // /settlements/{settlementId}\n    match /settlements/{settlementId} {\n        // Read: Privileged users can read all. DJs can read settlements that belong to them.\n        allow read: if isPrivivileged() || (request.auth != null && resource.data.djId == request.auth.uid);\n        // Create, Update, Delete: Only privileged users can manage settlements.\n        allow write: if isPrivileged();\n    }\n\n  }\n}\n"}]}}
