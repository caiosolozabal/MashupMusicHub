[debug] [2025-07-09T21:02:12.956Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Check if the user's custom token claim 'role' is admin or partner\n    function isManager() {\n      return request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // Check if the user is the owner of the document\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Managers can read and write any user document\n      allow read, write: if isManager();\n      \n      // Users can read and write their own document\n      allow read, update: if isOwner(userId);\n    }\n    \n    // Rules for 'events'\n    match /events/{eventId} {\n      // Managers can perform any operation on events\n      allow read, create, update, delete: if isManager();\n      \n      // DJs can read events they are assigned to\n      allow read: if request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid;\n      \n      // DJs can create events, but only for themselves\n      allow create: if request.auth.token.role == 'dj' && request.resource.data.dj_id == request.auth.uid;\n    }\n    \n    // Rules for 'settlements'\n    match /settlements/{settlementId} {\n      // Managers can perform any operation on settlements\n      allow read, create, update, delete: if isManager();\n      \n      // DJs can read settlements that belong to them\n      allow read: if request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid;\n    }\n\n    // Rules for 'agency_accounts'\n    match /agency_accounts/{accountId} {\n       // Only managers can read or write agency accounts\n      allow read, write: if isManager();\n    }\n  }\n}\n"}]}}
