[debug] [2026-01-06T01:58:12.464Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n    \n    // 🔐 USERS COLLECTION\n    // Rules for accessing user profile data.\n    match /users/{userId} {\n      allow get: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      allow list: if request.auth.token.role in ['admin', 'partner'];\n      allow create: if isOwner(userId);\n      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      allow delete: if false; // Deleting users is disallowed from the client for safety.\n    }\n\n    // 🔐 EVENTS COLLECTION\n    // Rules for accessing event data.\n    match /events/{eventId} {\n       // READ: Admins/partners can read any event. DJs can only read events they are assigned to.\n       allow read: if request.auth.token.role in ['admin', 'partner'] || \n                     (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n                     \n      // LIST: Admins/partners can list all events. DJs can list events to find their own.\n      // The client-side query for DJs MUST include `where('dj_id', '==', auth.uid)`.\n      allow list: if request.auth.token.role in ['admin', 'partner', 'dj'];\n\n      // CREATE: Admins, partners, and DJs can create new events.\n      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];\n\n      // UPDATE & DELETE: Allow any authenticated user to update or delete any event.\n      // This is a simplified rule to prevent permission errors.\n      // The application's UI logic is the primary guardrail for these actions.\n      allow update, delete: if request.auth != null;\n    }\n    \n    // 🔐 SETTLEMENTS COLLECTION\n    // Rules for financial settlement documents.\n    match /settlements/{settlementId} {\n        // READ: Admins/partners can read any settlement. DJs can only read their own.\n       allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);\n       // LIST: Admins/partners can list all settlements. DJs can list to find their own.\n       // The client-side query for DJs MUST include `where('djId', '==', auth.uid)`.\n       allow list: if request.auth.token.role in ['admin', 'partner', 'dj'];\n       // WRITE (Create, Update, Delete): Only admins and partners can manage settlements.\n      allow write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 AGENCY ACCOUNTS COLLECTION\n    // Rules for the agency's bank account information.\n    match /agency_accounts/{accountId} {\n      // Only admins and partners can read or write agency account details.\n      allow read, write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔒 FALLBACK RULE\n    // Explicitly deny all other access to prevent accidental exposure of data.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
