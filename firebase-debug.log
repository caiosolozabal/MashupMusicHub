[debug] [2026-01-06T03:55:08.844Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // -------------------------------------------------------------------------\n    // Helper Functions\n    // -------------------------------------------------------------------------\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    function getRole() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isAdmin() {\n      return getRole() == 'admin';\n    }\n\n    function isPartner() {\n        return getRole() == 'partner';\n    }\n\n    function isDJ() {\n        return getRole() == 'dj';\n    }\n\n    // -------------------------------------------------------------------------\n    // User Profiles\n    // -------------------------------------------------------------------------\n    match /users/{userId} {\n      allow read, update: if isOwner(userId) || isAdmin() || isPartner();\n      allow create: if isSignedIn(); // Allow any signed in user to create their own profile record.\n      // No delete for user profiles to prevent accidental data loss.\n    }\n\n    // -------------------------------------------------------------------------\n    // Events\n    // -------------------------------------------------------------------------\n    match /events/{eventId} {\n      allow read: if isSignedIn(); // All signed in users can read events\n      allow create: if isDJ() || isAdmin() || isPartner(); // DJs, Admins, and Partners can create\n      allow update: if isAdmin() || isPartner() || (isDJ() && resource.data.dj_id == request.auth.uid); // Admins, partners, or the assigned DJ can update\n      allow delete: if isAdmin() || isPartner(); // Only Admins and Partners can delete\n    }\n\n    // -------------------------------------------------------------------------\n    // Agency Accounts\n    // -------------------------------------------------------------------------\n    match /agency_accounts/{accountId} {\n        allow read: if isAdmin() || isPartner();\n        allow write: if isAdmin() || isPartner();\n    }\n    \n    // -------------------------------------------------------------------------\n    // Settlements - Only Admins, Partners, and the specific DJ can access\n    // -------------------------------------------------------------------------\n     match /settlements/{settlementId} {\n      allow read, create, update: if isAdmin() || isPartner() || (isDJ() && resource.data.djId == request.auth.uid);\n      allow delete: if isAdmin() || isPartner();\n    }\n\n    // Fallback rule: Deny all other access\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
