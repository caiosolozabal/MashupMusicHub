[debug] [2025-07-09T19:54:23.890Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check for admin or partner roles\n    function isManager() {\n      return request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'partner'];\n    }\n\n    // Users Collection\n    match /users/{userId} {\n      // Admins/Partners can read any user profile.\n      allow read: if isManager();\n\n      // Users can read and write to their own profile.\n      // Admins/Partners can also write/update any user profile.\n      allow write: if request.auth.uid == userId || isManager();\n    }\n\n    // Events Collection\n    match /events/{eventId} {\n      // Admins/Partners can read, create, update, and delete any event.\n      allow read, write, delete: if isManager();\n      \n      // DJs can read events they are assigned to.\n      allow get: if request.auth.uid != null && resource.data.dj_id == request.auth.uid;\n      allow list: if request.auth.uid != null && request.query.where.size() > 0 && request.query.where[0].field == 'dj_id' && request.query.where[0].value == request.auth.uid;\n\n      // DJs can create events, but only assign themselves.\n      allow create: if request.auth.uid != null && request.resource.data.dj_id == request.auth.uid;\n      \n      // DJs can update their own events.\n      allow update: if request.auth.uid != null && resource.data.dj_id == request.auth.uid;\n    }\n\n    // Settlements Collection (for financial closings)\n    match /settlements/{settlementId} {\n      // Only Admins/Partners can manage settlements.\n      allow read, write, delete: if isManager();\n    }\n\n    // Agency Accounts Collection\n    match /agency_accounts/{accountId} {\n       // Only Admins/Partners can manage agency bank accounts.\n      allow read, write, delete: if isManager();\n    }\n  }\n}\n"}]}}
