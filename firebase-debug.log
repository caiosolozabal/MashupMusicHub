[debug] [2025-07-10T02:07:45.315Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check for admin or partner roles from the auth token\n    function isAdminOrPartner() {\n      return request.auth.token.role == 'admin' || request.auth.token.role == 'partner';\n    }\n\n    // Users collection rules\n    match /users/{userId} {\n      // Admins/Partners can read any user profile (for management)\n      // Users can read and update their own profile\n      allow read, update: if request.auth.uid == userId || isAdminOrPartner();\n      \n      // Only admins can create or delete user records through dedicated functions/backend logic\n      // For this app, creation happens on first login, and we'll restrict deletion.\n      allow create: if request.auth.uid != null; // Allow creation for any authenticated user on first login\n      allow delete: if isAdminOrPartner(); // Only admins can delete users\n    }\n\n    // Events collection rules\n    match /events/{eventId} {\n      // Admins/Partners can perform any action on events\n      allow read, write: if isAdminOrPartner();\n\n      // DJs can read events assigned to them\n      allow get: if request.auth.uid == resource.data.dj_id;\n      allow list: if request.auth.uid == request.query.where.dj_id; // Allow DJ to list their own events via query\n\n      // DJs can create events, but only for themselves\n      allow create: if request.auth.uid != null && request.resource.data.dj_id == request.auth.uid;\n      \n      // DJs can update events assigned to them\n      allow update: if request.auth.uid == resource.data.dj_id;\n    }\n\n    // Settlements collection rules\n    match /settlements/{settlementId} {\n        // Admins/Partners can do anything with settlements\n        allow read, write: if isAdminOrPartner();\n\n        // DJs can read settlements that belong to them\n        allow get: if request.auth.uid == resource.data.djId;\n        allow list: if request.auth.uid == request.query.where.djId; // Allow DJ to query their own settlements\n    }\n    \n    // Agency accounts collection rules\n    match /agency_accounts/{accountId} {\n      // Only admins and partners can manage agency accounts\n      allow read, write: if isAdminOrPartner();\n    }\n  }\n}\n"}]}}
