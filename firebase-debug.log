[debug] [2025-07-21T23:28:40.417Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    // 🔐 users\n    match /users/{userId} {\n      allow read: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      allow list: if request.auth.token.role in ['admin', 'partner']; // ✅ necessário para dropdown\n      allow create: if request.auth.uid != null;\n      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);\n      allow delete: if false;\n    }\n\n    // 🔐 events\n    match /events/{eventId} {\n      allow read: if request.auth.token.role in ['admin', 'partner']\n               || (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      allow list: if request.auth.token.role in ['admin', 'partner']; // ✅ necessário para filtro por DJ\n      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];\n      allow update: if request.auth.token.role in ['admin', 'partner'] \n                 || (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);\n      allow delete: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 settlements\n    match /settlements/{settlementId} {\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);\n      allow write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 agency_accounts\n    match /agency_accounts/{accountId} {\n      allow read, write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔐 djs - Esta regra pode ser um legado, mas a manteremos conforme o plano. A regra crucial para o dropdown está em /users.\n    match /djs/{djId} {\n      allow read: if request.auth.token.role in ['admin', 'partner'] || \n                   (request.auth.token.role == 'dj' && request.auth.uid == djId);\n      allow write: if request.auth.token.role in ['admin', 'partner'];\n    }\n\n    // 🔒 fallback\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n"}]}}
