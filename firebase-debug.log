[debug] [2026-01-07T01:37:22.023Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // --- Helper Functions ---\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n    \n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data;\n    }\n    \n    function isAdmin() {\n      // Check for document existence before accessing data\n      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin';\n    }\n\n    function isPartner() {\n      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'partner';\n    }\n\n    function isDj() {\n      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'dj';\n    }\n\n    // --- Security Rules ---\n\n    // USER PROFILES (/users/{userId})\n    match /users/{userId} {\n      // ANY authenticated user can read ANY profile during this phase to verify roles.\n      // A user can always write to their own profile. Admins/Partners can write to any.\n      allow read, list: if isSignedIn(); \n      allow write: if isSignedIn() && (isOwner(userId) || isAdmin() || isPartner());\n    }\n\n    // EVENTS (/events/{eventId})\n    match /events/{eventId} {\n      // READ: Admins, partners, and the assigned DJ can read/list events.\n      allow read, list: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);\n      \n      // CREATE/UPDATE: Admins, partners, and a DJ creating/updating their own event.\n      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);\n      \n      // DELETE: Admins, partners, and the assigned DJ can delete their own event.\n      allow delete: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);\n    }\n    \n    // AGENCY ACCOUNTS (/agency_accounts/{accountId})\n    // Only admins and partners can manage agency accounts.\n    match /agency_accounts/{accountId} {\n        allow read, write, create, update, delete: if isAdmin() || isPartner();\n        allow list: if isAdmin() || isPartner();\n    }\n  }\n}\n"}]}}
