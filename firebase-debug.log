[debug] [2025-07-09T20:44:29.509Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if the user is an admin or partner.\n    function isManager() {\n      return request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'partner'];\n    }\n\n    // Users Collection\n    match /users/{userId} {\n      // A user can read and update their own data.\n      allow read, update: if request.auth.uid == userId;\n      // Managers can list and get any user's data.\n      allow list, get: if isManager();\n      // Managers can create and delete users (though typically done via backend functions).\n      allow create, delete: if isManager();\n    }\n\n    // Events Collection\n    match /events/{eventId} {\n      // Managers can perform any action on events. This covers list, get, create, update, delete.\n      allow read, write, delete: if isManager();\n\n      // DJs can read events assigned to them.\n      allow get, list: if request.auth.uid == resource.data.dj_id;\n\n      // DJs can create events, but only assign themselves.\n      allow create: if request.auth.uid != null && request.resource.data.dj_id == request.auth.uid;\n      \n      // DJs can update events assigned to them.\n      allow update: if request.auth.uid == resource.data.dj_id;\n    }\n\n    // Settlements Collection\n    match /settlements/{settlementId} {\n        // Managers can perform any action on settlements.\n        allow read, write, delete: if isManager();\n\n        // DJs can read settlements where they are the djId.\n        allow get, list: if request.auth.uid == resource.data.djId;\n    }\n\n    // Agency Accounts Collection\n    match /agency_accounts/{accountId} {\n        // Only Managers can perform actions on agency accounts.\n        allow read, write, delete: if isManager();\n    }\n  }\n}\n"}]}}
