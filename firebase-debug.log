[debug] [2025-07-10T03:04:18.989Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Check if the user is an Admin or Partner by their custom claim\n    function isOwner() {\n      return request.auth.token.role == 'admin' || request.auth.token.role == 'partner';\n    }\n\n    // Rules for the 'users' collection\n    match /users/{userId} {\n      // Admins/Partners can read any user document\n      // Users can read their own document\n      allow read: if isOwner() || request.auth.uid == userId;\n\n      // Users can update their own document\n      // Admins/Partners can update any user document\n      allow update: if isOwner() || request.auth.uid == userId;\n      \n      // Admins/Partners can list all users\n      allow list: if isOwner();\n\n      // Any authenticated user can create their own user document upon first login\n      allow create: if request.auth.uid == userId;\n    }\n\n    // Rules for the 'events' collection\n    match /events/{eventId} {\n      // Admins/Partners can perform any action on any event\n      allow read, write: if isOwner();\n      \n      // DJs can read events they are assigned to\n      allow read: if request.auth.uid == resource.data.dj_id;\n      \n      // DJs can create events (validation should ensure they assign it to themselves)\n      allow create: if request.auth.uid != null;\n    }\n    \n    // Rules for the 'settlements' collection\n    match /settlements/{settlementId} {\n        // Admins/Partners can perform any action on any settlement\n        allow read, write: if isOwner();\n\n        // DJs can read settlements that belong to them\n        allow read: if request.auth.uid == resource.data.djId;\n    }\n\n    // Rules for the 'agency_accounts' collection\n    match /agency_accounts/{accountId} {\n      // Only Admins/Partners can manage agency bank accounts\n      allow read, write: if isOwner();\n    }\n  }\n}\n"}]}}
