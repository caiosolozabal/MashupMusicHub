rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin/partner roles
    function isPrivileged() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'partner'];
    }

    // Users collection rules
    match /users/{userId} {
      // A user can read/write their own data.
      allow read, write: if request.auth.uid == userId;
      // Admin/Partner can read all user profiles (needed for DJ dropdowns).
      allow list, get: if isPrivileged();
    }

    // Agency Accounts rules
    match /agency_accounts/{accountId} {
      // Only Admin/Partner can create, read, update, delete agency accounts.
      allow read, write, create, delete: if isPrivileged();
      allow list: if isPrivileged();
    }
    
    // Events rules
    match /events/{eventId} {
      // Admin/Partner have full access.
      allow read, create, update, delete: if isPrivileged();
      
      // DJs can read their own events, but not others.
      allow get: if request.auth.uid == resource.data.dj_id;
      // DJs can list their own events.
      allow list: if request.auth.uid == request.query.where[0][2]; // Unsafe rule, but simple for `where('dj_id', '==', user.uid)`
      
      // Allow DJ to create an event for themselves
      allow create: if request.auth.uid != null && request.resource.data.dj_id == request.auth.uid;
      
      // Allow DJ to update their own event
      allow update: if request.auth.uid == resource.data.dj_id;
    }

    // Settlements rules
    match /settlements/{settlementId} {
      // Only Admin/Partner can create, read, list, update, or delete settlements.
      allow read, list, create, delete, update: if isPrivileged();
    }
  }
}
