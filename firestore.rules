/**
 * Core Philosophy:
 * This ruleset implements a Role-Based Access Control (RBAC) model combined with
 * a strict user-ownership model. Administrative users (admins) have broad
 * privileges, while standard users have explicit ownership of their data, such as
 * their user profile and promoter-specific guest lists. Sensitive financial
 * data is further restricted to 'admin' and 'finance' roles.
 *
 * Data Structure:
 * The data is organized into a mix of top-level collections for shared data
 * (e.g., /events, /djs) and user-scoped subcollections for private data
 * (e.g., /users/{userId}/...). A dedicated collection, /roles_admin, is used for
 * an efficient, non-hierarchical lookup of admin privileges.
 *
 * Key Security Decisions:
 * - Admin Access: A user is considered an admin if a document with their UID
 *   exists in the /roles_admin collection. This is a highly performant and
 *   scalable way to manage global permissions.
 * - User Privacy: Direct listing of the top-level /users collection is
 *   disallowed to protect user privacy. Users can only access their own data
 *   tree under /users/{userId}.
 * - Event Access Control: Due to the current data model, which lacks a denormalized
 *   list of collaborator UIDs on event documents, access to /events and their
 *   subcollections is restricted to admins to ensure security. This prevents
 *   unauthorized data access and is the safest default. The rules include comments
 *   on how to expand this if the data model is updated.
 * - Financial Data: Access to sensitive collections like /accounts and DJ
 *   settlements (/djs/{djId}/settlements) is strictly limited to users with
 *   'admin' or 'finance' roles, or in the case of settlements, the DJ who owns it.
 *
 * Denormalization for Authorization:
 * This ruleset relies on denormalization to function securely and efficiently.
 * - The `promoterId` is denormalized onto `GuestList` documents, allowing rules
 *   to grant write access without needing to read a separate user profile.
 * - The `djId` field on a user's profile links their authentication UID to their
 *   DJ record, enabling rules for settlements to verify ownership.
 *
 * Structural Segregation:
 * The ruleset leverages distinct paths for data with different access patterns.
 * For example, promoter-owned guest lists are stored under the user's private
 * path (/users/{userId}/guestLists), while event-specific guest lists are stored
 * under the public event path (/events/{eventId}/guestLists). This separation
 * simplifies list queries and enhances security.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * Used to enforce document and data tree ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the resource existed before the request.
     * CRITICAL for all update and delete operations to prevent acting on
     * non-existent documents.
     */
    function docExists() {
      return resource != null;
    }

    /**
     * Returns true if the user has administrative privileges.
     * Checks for the existence of a document in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Retrieves the requesting user's profile data document.
     * This function is used to check for user roles and other profile-based attributes.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/profile).data;
    }



    /**
     * Retrieves the role string from the user's profile.
     */
    function getUserRole() {
      return getUserData().role;
    }

    /**
     * Returns true if the user is an admin or has the 'finance' role.
     * Used to protect sensitive financial collections.
     */
    function isAdminOrFinance() {
      return isAdmin() || (isSignedIn() && getUserRole() == 'finance');
    }

    /**
     * Checks if the current user is the DJ associated with the given djId.
     * This is used to secure a DJ's personal settlement data.
     */
    function isAssociatedDJ(djId) {
      return isSignedIn() && getUserData().djId == djId && getUserRole() == 'dj';
    }


    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    /**
     * @description Users can manage their own profile, but cannot see or list other users' profiles.
     * @path        /users/{userId}/profile/{profileId}
     * @allow       A user (auth.uid='user123') creates their own profile document at /users/user123/profile/{profileId}. (create)
     * @deny        A user (auth.uid='user456') tries to read the profile at /users/user123/profile/{profileId}. (get)
     * @principle   Restricts access to a user's own data tree and enforces ownership.
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * @description Users can manage their own private guest lists.
     * @path        /users/{userId}/guestLists/{guestListId}
     * @allow       A promoter (auth.uid='user123') creates a guest list under their own path. (create)
     * @deny        A promoter (auth.uid='user456') tries to delete a guest list under /users/user123/guestLists/{guestListId}. (delete)
     * @principle   Enforces strict ownership for all operations within a user's private data space.
     */
    match /users/{userId}/guestLists/{guestListId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.promoterId == userId;
      allow update, delete: if docExists() && isOwner(userId);
    }

    // -------------------------------------------------------------------------
    // Administrative Roles (/roles_admin)
    // -------------------------------------------------------------------------

    /**
     * @description Only other admins can manage the list of admins. This collection is not readable by normal users.
     * @path        /roles_admin/{userId}
     * @allow       An admin creates a document for a new admin at /roles_admin/newUser123. (create)
     * @deny        A non-admin user tries to read any document in this collection. (get, list)
     * @principle   Secures administrative privileges by restricting modification of the role list to existing admins.
     */
    match /roles_admin/{userId} {
      allow get, list, create, update, delete: if isAdmin();
    }


    // -------------------------------------------------------------------------
    // Core Data Collections (/events, /djs, /accounts)
    // -------------------------------------------------------------------------

    /**
     * @description Manages event information.
     * @path        /events/{eventId}
     * @allow       An admin creates, updates, or deletes an event document. (create, update, delete)
     * @deny        A regular DJ user attempts to read or modify an event. (get, list, create, update, delete)
     * @principle   Restricts access to admins as a secure default. The data model lacks a denormalized list of user UIDs
     *              (e.g., a `memberUids` map) required to safely grant access to collaborators like DJs.
     */
    match /events/{eventId} {
      // TODO: To grant DJs or other collaborators access, denormalize a `memberUids` map onto this document
      // (e.g., { memberUids: { 'user-uid-of-dj': 'dj', 'user-uid-of-manager': 'manager' } })
      // and update the rule to: `isAdmin() || request.auth.uid in resource.data.memberUids`.
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Manages guest lists associated with a specific event.
     * @path        /events/{eventId}/guestLists/{guestListId}
     * @allow       A promoter creates a guest list for an event, setting their own UID as the 'promoterId'. (create)
     * @deny        A promoter tries to update a guest list where they are not the 'promoterId'. (update)
     * @principle   Allows any signed-in user to create a list for an event, but write access is restricted to the list's owner (promoter) or an admin.
     */
    match /events/{eventId}/guestLists/{guestListId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.promoterId == request.auth.uid && request.resource.data.eventId == eventId;
      allow update, delete: if docExists() && (isOwner(resource.data.promoterId) || isAdmin());
    }

    /**
     * @description Manages documents (e.g., contracts) associated with a specific event.
     * @path        /events/{eventId}/documents/{documentId}
     * @allow       An admin uploads a contract for an event. (create)
     * @deny        A DJ tries to view or list event documents. (get, list)
     * @principle   Inherits permissions from the parent event, restricting all access to admins as a secure default.
     */
    match /events/{eventId}/documents/{documentId} {
      allow get, list, delete, update: if docExists() && isAdmin();
      allow create: if isAdmin() && request.resource.data.eventId == eventId;
    }

    /**
     * @description Stores public profiles for DJs.
     * @path        /djs/{djId}
     * @allow       Any authenticated user can read the list of DJs and their profiles. (get, list)
     * @deny        A regular user tries to update a DJ's profile information. (update)
     * @principle   Public read for general application use, with writes restricted to administrators.
     */
    match /djs/{djId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Manages financial settlements for DJs. Access is highly restricted.
     * @path        /djs/{djId}/settlements/{settlementId}
     * @allow       A DJ with a matching 'djId' on their user profile views their own settlement. (get)
     * @allow       A user with the 'finance' role creates a new settlement for a DJ. (create)
     * @deny        A DJ tries to view the settlements of another DJ. (get, list)
     * @principle   Restricts access to sensitive financial data to the document owner (the DJ) or authorized financial staff.
     */
    match /djs/{djId}/settlements/{settlementId} {
      allow get, list: if isAssociatedDJ(djId) || isAdminOrFinance();
      allow create: if (isAssociatedDJ(djId) || isAdminOrFinance()) && request.resource.data.djId == djId;
      allow update, delete: if docExists() && (isAssociatedDJ(djId) || isAdminOrFinance());
    }

    /**
     * @description Manages sensitive bank account information for the agency.
     * @path        /accounts/{accountId}
     * @allow       A user with the 'finance' role reads an account's details. (get)
     * @deny        Any user without an 'admin' or 'finance' role attempts any operation. (get, list, create, update, delete)
     * @principle   Enforces strict role-based access for highly sensitive financial information.
     */
    match /accounts/{accountId} {
      allow get, list, create, update, delete: if isAdminOrFinance();
    }

    // CRITICAL: The IR defines a path "/guestLists/{guestListId}/guests/{guestId}" but no top-level "/guestLists" collection.
    // This rule is omitted because it cannot be securely implemented without a clear parent collection.
    // Guests should be a subcollection of a specific guest list, e.g., /events/{eventId}/guestLists/{guestListId}/guests/{guestId}.

  }
}