rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 🔐 users
    match /users/{userId} {
      // Admins/Partners can get any user. Users can get their own profile.
      allow get: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);
      // Admins/Partners can list users (e.g., to populate DJ dropdowns).
      allow list: if request.auth.token.role in ['admin', 'partner'];
      // Users can create their own document.
      allow create: if isOwner(userId);
      // Admins/Partners can update any user. Users can update their own profile.
      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);
      // Deletion is not allowed.
      allow delete: if false;
    }

    // 🔐 events
    match /events/{eventId} {
      // Admins/Partners can read any event. DJs can read their own events.
      allow read: if request.auth.token.role in ['admin', 'partner'] || 
                   (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);
      // Admins, Partners, and DJs can create events.
      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];
      // Admins/Partners can update any event. DJs can update their own events.
      allow update: if request.auth.token.role in ['admin', 'partner'] || 
                     (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);
      // Only Admins/Partners can delete events.
      allow delete: if request.auth.token.role in ['admin', 'partner'];
    }

    // 🔐 settlements
    match /settlements/{settlementId} {
       // Admins/Partners can read any settlement. DJs can read their own settlements.
      allow read: if request.auth.token.role in ['admin', 'partner'] || 
                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);
      // Only Admins/Partners can write settlements.
      allow write: if request.auth.token.role in ['admin', 'partner'];
    }

    // 🔐 agency_accounts
    match /agency_accounts/{accountId} {
      // Only Admins/Partners can read/write agency accounts.
      allow read, write: if request.auth.token.role in ['admin', 'partner'];
    }

    // 🔒 fallback: deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
