
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin/partner roles
    function isPrivileged() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'partner'];
    }
    
    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // /users/{userId}
    match /users/{userId} {
      // Anyone can create their own user document on first login (handled by AuthContext)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users can read their own data. Privileged users can read anyone's data.
      allow read: if isOwner(userId) || isPrivileged();
      // Users can update their own data. Privileged users can update anyone's data.
      allow update: if isOwner(userId) || isPrivileged();
      // Only privileged users can delete user accounts from Firestore.
      allow delete: if isPrivileged();
    }

    // /events/{eventId}
    match /events/{eventId} {
      // Read: Privileged users can read all. DJs can read events assigned to them.
      allow read: if isPrivileged() || (request.auth != null && resource.data.dj_id == request.auth.uid);
      // Create: Any authenticated user can create an event (DJ, admin, partner).
      allow create: if request.auth != null;
      // Update: Privileged users can update any event. DJs can only update events assigned to them.
      // Also allow updating settlementId by privileged users.
      allow update: if isPrivileged() || (request.auth != null && resource.data.dj_id == request.auth.uid);
      // Delete: Only privileged users can delete events.
      allow delete: if isPrivileged();
    }
    
    // /agency_accounts/{accountId}
    match /agency_accounts/{accountId} {
        // Only privileged users can manage agency accounts.
    	allow read, write: if isPrivileged();
    }

    // /settlements/{settlementId}
    match /settlements/{settlementId} {
        // Read: Privileged users can read all. DJs can read settlements that belong to them.
        allow read: if isPrivivileged() || (request.auth != null && resource.data.djId == request.auth.uid);
        // Create, Update, Delete: Only privileged users can manage settlements.
        allow write: if isPrivileged();
    }

  }
}
