
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin or partner
    function isAdminOrPartner(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role in ['admin', 'partner'];
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can read their own data
      // Admins/partners can read any user's data
      allow read: if request.auth.uid == userId || isAdminOrPartner(request.auth.uid);

      // Only the user themselves can update their own data.
      // Admins/partners can also update any user's data.
      allow write: if request.auth.uid == userId || isAdminOrPartner(request.auth.uid);
      
      // Creating a user document is handled by the AuthProvider on first login
      allow create: if request.auth.uid == userId;
    }

    // Rules for the 'events' collection
    match /events/{eventId} {
        // Admins and partners can read any event.
        // DJs can read events assigned to them.
        allow read: if isAdminOrPartner(request.auth.uid) || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj' && resource.data.dj_id == request.auth.uid);

        // Admins and partners can create, update, and delete any event.
        // DJs can create events and update events assigned to them.
        allow create: if request.auth != null; // Any authenticated user can create, logic is handled in UI
        allow update: if isAdminOrPartner(request.auth.uid) || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj' && resource.data.dj_id == request.auth.uid);
        allow delete: if isAdminOrPartner(request.auth.uid);
    }
    
    // Rules for the 'settlements' collection
    match /settlements/{settlementId} {
        // Admins and partners can manage settlements
        allow read, write, create, delete: if isAdminOrPartner(request.auth.uid);
    }
    
    // Rules for the 'agency_accounts' collection
    match /agency_accounts/{accountId} {
      // Only admins and partners can manage agency accounts
      allow read, write, create, delete: if isAdminOrPartner(request.auth.uid);
    }
  }
}
