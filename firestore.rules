
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ATENÇÃO: Regras de segurança temporariamente relaxadas para migração de dados.
    // Qualquer usuário autenticado pode ler e escrever em qualquer documento.
    // RESTAURE AS REGRAS DE SEGURANÇA ORIGINAIS APÓS A MIGRAÇÃO!
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
