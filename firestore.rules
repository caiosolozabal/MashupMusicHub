
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Function to get the user's role from their profile document.
    // This is the core of our role-based access control.
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isRole(role) {
        return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isRole('admin');
    }

    function isPartner() {
        return isRole('partner');
    }
    
    function isDj() {
      return isRole('dj');
    }

    // SECURITY RULES

    // USER PROFILES (/users/{userId})
    // Crucial Rule: A user can always read their OWN profile. This breaks the Catch-22.
    // Admins and Partners can read ANY profile and list all users.
    // Users can update their own profile. Admins/Partners can update any.
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isPartner());
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin() || isPartner());
      allow list: if isAdmin() || isPartner();
    }

    // EVENTS (/events/{eventId})
    // Admins/Partners can read/write all events.
    // DJs can only read events where their ID is listed in the 'dj_id' field.
    match /events/{eventId} {
      allow read, list: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);
      allow create, update, delete: if isAdmin() || isPartner() || (isDj() && request.auth.uid == request.resource.data.dj_id);
    }
    
    // AGENCY ACCOUNTS (/agency_accounts/{accountId})
    // Only admins and partners can manage agency accounts.
    match /agency_accounts/{accountId} {
        allow read, list, create, update, delete: if isAdmin() || isPartner();
    }
  }
}
