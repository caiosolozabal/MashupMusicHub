
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole(userId) {
      // Safely get role data, return null if user doc or role doesn't exist
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole(request.auth.uid) == 'admin';
    }

    function isPartner() {
      return isSignedIn() && getRole(request.auth.uid) == 'partner';
    }

    function isDj() {
       return isSignedIn() && getRole(request.auth.uid) == 'dj';
    }

    // USER PROFILES
    // Admins/Partners can read any profile. Users can read/update their own.
    match /users/{userId} {
      allow read: if (isSignedIn() && (isOwner(userId) || isAdmin() || isPartner()));
      allow update: if (isSignedIn() && (isOwner(userId) || isAdmin() || isPartner()));
      // Allow create for new users (though this is typically handled by trusted server code or first login)
      allow create: if isSignedIn();
    }

    // Collection group query for users (used in settings)
    match /{path=**}/users/{userId} {
       allow list: if isAdmin() || isPartner();
    }
    

    // AGENCY ACCOUNTS
    // Only admins and partners can manage agency accounts.
    match /agency_accounts/{accountId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    // EVENTS
    // Admins/partners can read/write all events.
    // DJs can read events assigned to them.
    match /events/{eventId} {
      // Read access
      allow get: if (isAdmin() || isPartner()) || (isDj() && resource.data.dj_id == request.auth.uid);
      allow list: if isAdmin() || isPartner() || isDj(); // DJ list queries are filtered in the app code
      
      // Write access
      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);
      allow delete: if isAdmin() || isPartner();
    }
  }
}
