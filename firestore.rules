rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPartner() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }

    function isDj() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj';
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, update, create: if request.auth.uid == userId || isAdmin() || isPartner();
      allow list: if isAdmin() || isPartner();
    }
    
    match /agency_accounts/{accountId} {
       allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /events/{eventId} {
      // Regra de Listagem Protegida: DJs listam apenas seus próprios eventos. Admins listam tudo.
      allow list: if isAdmin() || isPartner() || (isDj() && request.query.limit <= 500 && (request.query.filters.dj_id == request.auth.uid || request.query.filters.size() == 0));
      // Regra de Leitura: Qualquer logado pode ver detalhes (necessário para a visualização da agenda global se permitido).
      allow read: if isSignedIn();
      
      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);
      allow delete: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);
    }
    
    match /settlements/{settlementId} {
        allow read, list: if isAdmin() || isPartner() || (isDj() && resource.data.djId == request.auth.uid);
        allow create, update, delete: if isAdmin() || isPartner();
    }

    match /rental_items/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isPartner();
    }

    match /rental_quotes/{quoteId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /app_config/{configId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
