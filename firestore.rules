
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin/partner roles
    function isAdminOrPartner() {
      return request.auth.token.role == 'admin' || request.auth.token.role == 'partner';
    }

    // Users Collection
    match /users/{userId} {
      // Any authenticated user can update their own document.
      // Admins/partners can read all user documents (to list DJs, etc.).
      allow read, update: if request.auth != null && (request.auth.uid == userId || isAdminOrPartner());
      
      // Only admins/partners can create or delete users through this setup.
      allow create, delete: if isAdminOrPartner();
    }

    // Agency Accounts Collection
    match /agency_accounts/{accountId} {
      // Only Admins and Partners can manage agency accounts.
      allow read, write: if isAdminOrPartner();
    }

    // Events Collection
    match /events/{eventId} {
      // Admins/Partners can do anything.
      allow read, write: if isAdminOrPartner();
      
      // DJs can read events assigned to them.
      // Allow create for DJs as well, with client-side logic ensuring they assign to themselves.
      allow create: if request.auth.token.role == 'dj';
      allow read: if request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid;
    }
    
    // Settlements Collection
    match /settlements/{settlementId} {
        // Admins/Partners can do anything with settlements.
        allow read, write: if isAdminOrPartner();
        
        // DJs can only read settlements that belong to them.
        allow read: if request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid;
    }
  }
}
