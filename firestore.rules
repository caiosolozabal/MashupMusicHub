
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to make rules more readable and reusable.
    function isAuth() {
      return request.auth != null;
    }

    function isAdminOrPartner() {
      return isAuth() && request.auth.token.role in ['admin', 'partner'];
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Admins/Partners can read any user profile (to list DJs, etc.).
      // Any authenticated user can read their own profile.
      allow read: if isAdminOrPartner() || isOwner(userId);

      // Only an authenticated user can update their own profile.
      // Admins/Partners can update any profile (to change roles, etc.).
      allow update: if isAdminOrPartner() || isOwner(userId);
      
      // Prevent user creation from client-side for security.
      // Creation should be handled by server-side logic (Firebase Auth triggers).
      allow create: if isAuth();
    }

    // --- Events ---
    match /events/{eventId} {
      // Admins/Partners can read/write all events.
      allow read, write: if isAdminOrPartner();

      // DJs can read events they are assigned to.
      // They can also create new events for themselves.
      // They can only update events they are assigned to.
      allow read, update: if isAuth() && resource.data.dj_id == request.auth.uid;
      allow create: if isAuth();
    }
    
    // --- Financial Settlements ---
    match /settlements/{settlementId} {
        // Admins/Partners can read/write all settlements.
        allow read, write: if isAdminOrPartner();

        // DJs can only read settlements that belong to them.
        allow read: if isAuth() && resource.data.djId == request.auth.uid;
    }

    // --- Agency Bank Accounts ---
    match /agency_accounts/{accountId} {
      // Only Admins/Partners can manage agency bank accounts.
      allow read, write: if isAdminOrPartner();
    }
  }
}
