
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regra global: Permite leitura e escrita para qualquer usuário autenticado.
    // Esta é uma regra de reversão para restaurar a funcionalidade.
    // A segurança granular pode ser reimplementada passo a passo posteriormente.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
