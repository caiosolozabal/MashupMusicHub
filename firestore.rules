
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------------------------------------------------------
    // Migration Rules - TEMPORARIAMENTE ABERTAS
    // -------------------------------------------------------------------------
    // Estas regras permitem que qualquer usuário autenticado leia e escreva
    // em qualquer documento. Isto é necessário para a migração inicial de dados.
    // DEVE SER REVERTIDO PARA REGRAS MAIS RÍGIDAS APÓS A MIGRAÇÃO.
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
