
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Function to get the user's role from their profile document.
    // This is the core of our role-based access control.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'admin';
    }

    function isPartner() {
        return isSignedIn() && getUserRole(request.auth.uid) == 'partner';
    }
    
    function isDj() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'dj';
    }

    // SECURITY RULES

    // USER PROFILES (/users/{userId})
    // Users can read their own profile. This is CRUCIAL to break the Catch-22.
    // Admins and Partners can read any profile and list all users.
    // Users can update their own profile. Admins/Partners can update any.
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || isPartner());
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin() || isPartner());
      allow list: if isAdmin() || isPartner();
    }

    // EVENTS (/events/{eventId})
    // Admins/Partners can read/write all events.
    // DJs can only read events where their ID is listed.
    match /events/{eventId} {
      allow read: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);
      allow list: if isAdmin() || isPartner() || isDj();
      allow create, update, delete: if isAdmin() || isPartner();
    }
    
    // AGENCY ACCOUNTS (/agency_accounts/{accountId})
    // Only admins and partners can manage agency accounts.
    match /agency_accounts/{accountId} {
        allow read, list, create, update, delete: if isAdmin() || isPartner();
    }
  }
}
