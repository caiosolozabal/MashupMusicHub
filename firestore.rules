
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // 🔐 USERS COLLECTION
    // Rules for accessing user profile data.
    match /users/{userId} {
      allow get: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);
      allow list: if request.auth.token.role in ['admin', 'partner'];
      allow create: if isOwner(userId);
      allow update: if request.auth.token.role in ['admin', 'partner'] || isOwner(userId);
      allow delete: if false; // Deleting users is disallowed from the client for safety.
    }

    // 🔐 EVENTS COLLECTION
    // Rules for accessing event data.
    match /events/{eventId} {
       // READ: Admins/partners can read any event. DJs can only read events they are assigned to.
       allow read: if request.auth.token.role in ['admin', 'partner'] || 
                     (request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid);
                     
      // LIST: Admins/partners can list all events. DJs can list events to find their own.
      // The client-side query for DJs MUST include `where('dj_id', '==', auth.uid)`.
      allow list: if request.auth.token.role in ['admin', 'partner', 'dj'];

      // CREATE: Admins, partners, and DJs can create new events.
      allow create: if request.auth.token.role in ['admin', 'partner', 'dj'];

      // UPDATE & DELETE: Allow any authenticated user to update or delete any event.
      // This is a simplified rule to prevent permission errors.
      // The application's UI logic is the primary guardrail for these actions.
      allow update, delete: if request.auth != null;
    }
    
    // 🔐 SETTLEMENTS COLLECTION
    // Rules for financial settlement documents.
    match /settlements/{settlementId} {
        // READ: Admins/partners can read any settlement. DJs can only read their own.
       allow read: if request.auth.token.role in ['admin', 'partner'] || 
                   (request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid);
       // LIST: Admins/partners can list all settlements. DJs can list to find their own.
       // The client-side query for DJs MUST include `where('djId', '==', auth.uid)`.
       allow list: if request.auth.token.role in ['admin', 'partner', 'dj'];
       // WRITE (Create, Update, Delete): Only admins and partners can manage settlements.
      allow write: if request.auth.token.role in ['admin', 'partner'];
    }

    // 🔐 AGENCY ACCOUNTS COLLECTION
    // Rules for the agency's bank account information.
    match /agency_accounts/{accountId} {
      // Only admins and partners can read or write agency account details.
      allow read, write: if request.auth.token.role in ['admin', 'partner'];
    }

    // 🔒 FALLBACK RULE
    // Explicitly deny all other access to prevent accidental exposure of data.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
