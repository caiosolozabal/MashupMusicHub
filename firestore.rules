
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Check if the user's custom token claim 'role' is admin or partner
    function isManager() {
      return request.auth.token.role in ['admin', 'partner'];
    }

    // Check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Managers can read and write any user document
      allow read, write: if isManager();
      
      // Users can read and write their own document
      allow read, update: if isOwner(userId);
    }
    
    // Rules for 'events'
    match /events/{eventId} {
      // Managers can perform any operation on events
      allow read, create, update, delete: if isManager();
      
      // DJs can read events they are assigned to
      allow read: if request.auth.token.role == 'dj' && resource.data.dj_id == request.auth.uid;
      
      // DJs can create events, but only for themselves
      allow create: if request.auth.token.role == 'dj' && request.resource.data.dj_id == request.auth.uid;
    }
    
    // Rules for 'settlements'
    match /settlements/{settlementId} {
      // Managers can perform any operation on settlements
      allow read, create, update, delete: if isManager();
      
      // DJs can read settlements that belong to them
      allow read: if request.auth.token.role == 'dj' && resource.data.djId == request.auth.uid;
    }

    // Rules for 'agency_accounts'
    match /agency_accounts/{accountId} {
       // Only managers can read or write agency accounts
      allow read, write: if isManager();
    }
  }
}
