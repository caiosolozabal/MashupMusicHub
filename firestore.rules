rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Auxiliares básicos
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isPartner() {
      return isSignedIn() && getUserData().role == 'partner';
    }

    function isDj() {
      return isSignedIn() && getUserData().role == 'dj';
    }

    // Regras de Usuários - Prioridade para leitura do próprio perfil para evitar erro no AuthContext
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isPartner());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isPartner());
      allow list: if isAdmin() || isPartner();
    }
    
    match /agency_accounts/{accountId} {
       allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /events/{eventId} {
      allow list: if isAdmin() || isPartner() || (isDj() && request.query.limit <= 500 && (request.query.filters.dj_id == request.auth.uid || request.query.filters.size() == 0));
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isPartner() || (isDj() && request.resource.data.dj_id == request.auth.uid);
      allow delete: if isAdmin() || isPartner() || (isDj() && resource.data.dj_id == request.auth.uid);
    }
    
    match /settlements/{settlementId} {
        allow read, list: if isAdmin() || isPartner() || (isDj() && resource.data.djId == request.auth.uid);
        allow create, update, delete: if isAdmin() || isPartner();
    }

    match /rental_items/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isPartner();
    }

    match /rental_quotes/{quoteId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /app_config/{configId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /tasks/{taskId} {
      function isStaff() { return isAdmin() || isPartner(); }
      function isOwner() { return isSignedIn() && request.auth.uid == resource.data.ownerUid; }
      function isAssignee() {
        return isSignedIn()
          && resource.data.assignedToUids != null
          && (request.auth.uid in resource.data.assignedToUids);
      }
      function isCreator() { return isSignedIn() && request.auth.uid == resource.data.createdByUid; }

      allow read, list: if isStaff() || isOwner() || isAssignee();

      allow create: if isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.ownerUid is string
        && request.resource.data.title is string
        && request.resource.data.status is string
        && (
          (request.resource.data.ownerUid == request.auth.uid)
          || (request.resource.data.ownerUid != request.auth.uid
              && request.resource.data.status == "pending_acceptance")
        );

      allow update: if (isStaff() || isOwner() || isAssignee())
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          isStaff()
          || resource.data.status != "pending_acceptance"
          || (resource.data.status == "pending_acceptance" && isOwner())
        );

      allow delete: if isStaff() || isCreator();
    }

    // Regras para o Módulo de Captação de Convidados
    match /guest_events/{eventId} {
      allow read: if true; 
      allow list, create, update, delete: if isAdmin() || isPartner();
      
      match /lists/{listId} {
        allow read: if true; 
        allow list, create, update, delete: if isAdmin() || isPartner();
      }
    }

    match /guest_submissions/{submissionId} {
      allow create: if true; 
      // Permite listagem pública SE filtrada por listId (usado na página de stats)
      allow list: if isAdmin() || isPartner() || request.query.filters.listId != null;
      allow read, update, delete: if isAdmin() || isPartner();
    }

    match /contacts/{contactId} {
      allow read, list, create, update, delete: if isAdmin() || isPartner();
    }

    match /slugs/{slug} {
      allow read: if true; 
      allow create, update, delete: if isAdmin() || isPartner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}