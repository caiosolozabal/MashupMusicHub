rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-allow rule for any authenticated user.
    // This allows the application to function without Firestore permission errors.
    // The application logic itself is responsible for showing the correct data to the correct user roles.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
